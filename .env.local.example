# Copy this file to .env.local and fill in your Firebase values.
# Get these from: Firebase Console → Project Settings → Your apps → Web app config

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
# Local dev: use your-project.firebaseapp.com (popup sign-in)
# Production (Vercel): use your live domain, e.g. linkedin-to-x.vercel.app
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Local dev only — skip Firebase login on localhost
NEXT_PUBLIC_BYPASS_AUTH=true

# ─── Firebase setup (one-time) ───────────────────────────────────────────────
#
# 1. Go to https://console.firebase.google.com → Create project
# 2. Project Settings → Your apps → Add web app → copy the config values above
# 3. Authentication → Sign-in method → Enable Google → Save
# 4. Authentication → Settings → Authorized domains → add "localhost"
# 5. Add your live domain (e.g. linkedin-to-x.vercel.app) to Authorized domains
# 6. Production: set NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN to your live domain (not firebaseapp.com)
#    and redeploy. next.config.ts proxies /__/auth/* to Firebase for redirect sign-in.
#
# Google OAuth is configured automatically by Firebase — no separate
# Google Cloud OAuth client setup is required for basic Google sign-in.
